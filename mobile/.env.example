# URL del API local (10.0.2.2 = localhost desde emulador Android)
# Para dispositivo físico usa la IP de la PC: http://192.168.x.x:3000
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Clerk — usar las claves de tu app en https://dashboard.clerk.com
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# PostHog — obtener en https://app.posthog.com → Project Settings → API Keys
EXPO_PUBLIC_POSTHOG_API_KEY=phc_...
