PORT=3000

# PostgreSQL — desarrollo local (docker-compose.yml) o Supabase
# Producción: usar Transaction pooler de Supabase (puerto 6543)
# Migraciones:  usar Session mode (puerto 5432)
DATABASE_URL=postgres://user:password@localhost:5432/epti_subs

# Supabase — Dashboard > Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Orígenes permitidos en CORS (separados por coma, sin espacios)
# Agregar la IP LAN para pruebas con dispositivo físico
CORS_ORIGIN=http://localhost:8081
