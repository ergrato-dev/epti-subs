{
  // ── TypeScript ─────────────────────────────────────────────────────────────
  "typescript.tsdk": "mobile/node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  // ── Editor ─────────────────────────────────────────────────────────────────
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 2,
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },

  // ── Files ──────────────────────────────────────────────────────────────────
  "files.exclude": {
    "**/.expo": true,
    "**/node_modules": true,
    "**/.git": false
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.expo": true,
    "**/pnpm-lock.yaml": true
  },

  // ── Peacock / Tema ─────────────────────────────────────────────────────────
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#142c51",
    "activityBar.background": "#142c51",
    "activityBar.foreground": "#e7e7e7",
    "activityBar.inactiveForeground": "#e7e7e799",
    "activityBarBadge.background": "#b32c61",
    "activityBarBadge.foreground": "#e7e7e7",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#142c51",
    "statusBar.background": "#0a1628",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#142c51",
    "statusBarItem.remoteBackground": "#0a1628",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#0a1628",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#0a162899",
    "titleBar.inactiveForeground": "#e7e7e799"
  },
  "peacock.color": "#0A1628"
}
